# ═══════════════════════════════════════════════════════════════
# Audity — Secrets only
# Network config (RPC, chain ID, explorer) lives in src/network.ts
# ═══════════════════════════════════════════════════════════════

# Your EVM address that receives STT payments (0x... format)
SERVER_ADDRESS=0xYourWalletAddress

# Agent wallet private key — NO 0x prefix
AGENT_PRIVATE_KEY=

# LLM API keys
GROQ_API_KEY=

# Deploy contracts first, then paste addresses here
SECURITY_REGISTRY_ADDRESS=0xYourSecurityRegistryAddress
WATCHLIST_HANDLER_ADDRESS=0xYourWatchlistHandlerAddress
