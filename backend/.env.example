# Secrets only — everything else is hardcoded in the codebase

SERVER_ADDRESS=0xYourWalletAddress
AGENT_PRIVATE_KEY=your_private_key_no_0x_prefix
GROQ_API_KEY=your_groq_key

# Deploy SecurityRegistry.sol then paste the address here
SECURITY_REGISTRY_ADDRESS=0xYourSecurityRegistryAddress

# Deploy WatchlistHandler.sol then paste the address here
WATCHLIST_HANDLER_ADDRESS=0xYourWatchlistHandlerAddress
